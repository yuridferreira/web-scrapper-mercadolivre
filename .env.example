PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/promo_monitor?schema=public"
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Fallback de notificação apenas para produtos sem dono (criados via REST,
# sem telegramChatId). Produtos cadastrados pelo bot notificam quem os
# cadastrou, não necessariamente este chat.
TELEGRAM_CHAT_ID=your_chat_id_here
CRON_SCHEDULE=0 * * * *
SCRAPER_CONCURRENCY=2